print("")

ebook_results = generate_all_covers(pipe, BOOK_COVERS, OUTPUT_DIR, "ebook")

# Summary
print("\n" + "="*60)
print("GENERATION COMPLETE")
print("="*60)
success = sum(1 for r in ebook_results if r["status"] == "success")
failed = sum(1 for r in ebook_results if r["status"] == "error")
print(f"Success: {success}/{len(ebook_results)}")
print(f"Failed: {failed}/{len(ebook_results)}")

