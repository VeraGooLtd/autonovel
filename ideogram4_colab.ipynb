# =============================================================================
# CELL 6: Helper Functions
# =============================================================================
def generate_cover(pipe, prompt, width, height, seed=None, steps=20, guidance=7.5):
    """Generate a single cover image."""
    if seed is None:
        seed = int(time.time()) % (2**32)
    
    generator = torch.Generator("cuda").manual_seed(seed)
    
    result = pipe(
        prompt=prompt,
        width=width,
        height=height,
        num_inference_steps=steps,
        guidance_scale=guidance,
        generator=generator
    )
    
    return result.images[0]

def sanitize_filename(title):
    """Create filesystem-safe filename."""
    return title.lower().replace(" ", "-").replace("'", "").replace(".", "")

def generate_all_covers(pipe, books, output_dir, cover_type="ebook"):
    """Generate covers for all books."""
    specs = COVER_SPECS[cover_type]
    results = []
    
    for book in books:
        title = book["title"]
        safe_name = sanitize_filename(title)
        
        # Generate front cover
        prompt = book["ebook_prompts"]["front"]
        print(f"\n{'='*60}")
        print(f"Generating: {title} ({cover_type})")
        print(f"Prompt: {prompt[:100]}...")
        
        try:
            image = generate_cover(
                pipe, prompt,
                specs["width"], specs["height"]
            )
            
            # Save
            filename = f"{safe_name}-{cover_type}-cover.png"
            filepath = os.path.join(output_dir, filename)
            image.save(filepath, "PNG", dpi=(specs["dpi"], specs["dpi"]))
            
            results.append({
                "title": title,
                "file": filepath,
                "filename": filename,
                "status": "success"
            })
            print(f"✅ Saved: {filename}")
            
        except Exception as e:
            results.append({
                "title": title,
                "status": "error",
                "error": str(e)
            })
            print(f"❌ Error: {e}")
    
    return results

