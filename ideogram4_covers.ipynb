      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 3: Load Ideogram 4",
        "import torch, os, time",
        "from diffusers import DiffusionPipeline",
        "",
        "pipe = DiffusionPipeline.from_pretrained('ideogram-ai/ideogram-4-nf4', torch_dtype=torch.bfloat16)",
        "pipe.to('cuda')",
        "print('Ideogram 4 loaded! GPU:', torch.cuda.get_device_name(0))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 4: Generate all 11 ebook covers",
        "OUTPUT = '/content/covers'",
        "os.makedirs(OUTPUT, exist_ok=True)",
        "",
        "covers = [",
        "  ('the-genesis-engine', 'The Genesis Engine',",
        "   'Middle grade sci-fi book cover. Title The Genesis Engine in bold futuristic font at top. Author Daniel Ryan at bottom. A massive engineered fungal spore pod on Mars surface, Earth visible in orange sky. Red Martian landscape with rocky terrain. The pod has glowing bioluminescent veins. Clean, bold, slightly cartoonish, middle grade friendly. 1600x2400.'),",
        "  ('the-martian-spore', 'The Martian Spore',",
        "   'Middle grade sci-fi book cover. Title The Martian Spore in bold futuristic font at top. Author Daniel Ryan at bottom. Cracked Martian soil with glowing green fungal mycelium spreading across cracks. Warning signs planted in ground. A small habitat dome in background. Clean, bold, slightly cartoonish. 1600x2400.'),",
        "  ('the-crimson-bloom', 'The Crimson Bloom',",
        "   'Middle grade sci-fi book cover. Title The Crimson Bloom in bold futuristic font at top. Author Daniel Ryan at bottom. Massive crimson-red fungal bloom spreading across Martian surface viewed from space. Bloom forms spiral pattern. Small colony dome at edge. Clean, bold, slightly cartoonish. 1600x2400.'),",
        "  ('sporefall', 'Sporefall',",
        "   'YA sci-fi horror book cover. Title Sporefall in large distressed font at top. Author Daniel Ryan at bottom. Terrifying fungal fruiting body emerging from dark rainforest canopy releasing clouds of spores. Small research camp below with tiny fleeing figures. Dark, atmospheric, stylized. Bold colors. 1600x2400.'),",
        "  ('mycelial-tide', 'Mycelial Tide',",
        "   'YA sci-fi horror book cover. Title Mycelial Tide in large distressed font at top. Author Daniel Ryan at bottom. Wall of mycelium consuming a city street rising like tidal wave. Cars and buildings being overtaken. Dramatic street-level perspective looking up. Dark, atmospheric, stylized. 1600x2400.'),",
        "  ('mycelial-earth', 'Mycelial Earth',",
        "   'YA sci-fi horror book cover. Title Mycelial Earth in large distressed font at top. Author Daniel Ryan at bottom. Earth from space with continents covered in web of glowing fungal mycelium. Small spaceship approaching. Epic scale. Dark, atmospheric, stylized. 1600x2400.'),",
        "  ('the-salami-saboteur', 'The Salami Saboteur',",
        "   'Middle grade mystery humor book cover. Title The Salami Saboteur in large playful font at top. Author Daniel Ryan at bottom. Hand-drawn doodle style like Diary of a Wimpy Kid. Ginger cat in tiny black mask sneaking away with enormous salami over shoulder. 9-year-old girl with glasses and a bulldog looking shocked. Dog has X-eyes. Sketch/doodle aesthetic with white background. 1600x2400.'),",
        "  ('the-glass-vaults-gambit', 'The Glass Vaults Gambit',",
        "   'Middle grade mystery humor book cover. Title The Glass Vaults Gambit in large playful font at top. Author Daniel Ryan at bottom. Hand-drawn doodle style like Diary of a Wimpy Kid. Shopping mall at night with visible security laser grid through skylight. Ginger cat in black turtleneck crawling through air duct. Girl with glasses and bulldog peeking from behind potted plant. Sketch/doodle aesthetic. 1600x2400.'),",
        "  ('station-zero', 'Station Zero',",
        "   'YA sci-fi book cover. Title Station Zero in bold futuristic font at top. Author Daniel Ryan at bottom. Derelict space station floating in deep space with single blinking light. Small shuttle approaching. Cold, dark, vast. Clean sci-fi aesthetic with bold typography. 1600x2400.'),",
        "  ('the-echo-chamber', 'The Echo Chamber',",
        "   'YA sci-fi thriller book cover. Title The Echo Chamber in bold tech-thriller font at top. Author Daniel Ryan at bottom. Human face reflected in phone screen but reflection is AI avatar slightly uncanny. Glitch effects, data streams, social media icons floating. Dark, modern, tech-thriller aesthetic. 1600x2400.'),",
        "  ('the-silent-strata', 'The Silent Strata',",
        "   'YA sci-fi book cover. Title The Silent Strata in bold futuristic font at top. Author Daniel Ryan at bottom. Cross-section view of Earth crust with layers of rock getting darker deeper down. In deepest layer, ancient alien structure glows faintly. Tiny drill approaching from above. Clean sci-fi aesthetic. 1600x2400.'),",
        "]",
        "",
        "for slug, title, prompt in covers:",
        "    print(f'Generating: {title}...')",
        "    img = pipe(prompt=prompt, width=1600, height=2400, num_inference_steps=25, guidance_scale=7.5).images[0]",
        "    path = f'{OUTPUT}/{slug}-ebook-cover.png'",
        "    img.save(path)",
        "    print(f'  OK: {path}')",
        "",
        "print('\\nAll 11 covers generated!')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
