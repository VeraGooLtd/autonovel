      "source": ["# Ideogram 4 Cover Generation for D2D Publishing\n", "\n", "Generate all 11 ebook covers using Ideogram 4 (nf4) on Google Colab GPU."]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 1: Install dependencies",
        "!pip install -q diffusers transformers accelerate huggingface_hub",
        "!pip install -q omegaconf peft",
        "print('Dependencies installed!')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 2: Login to HuggingFace (required for model download)",
        "from huggingface_hub import login",
        "login()  # Paste your HF token at prompt. Get free token at https://huggingface.co/settings/tokens"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 3: Download and load Ideogram 4 (nf4 variant — fits in ~16GB VRAM)",
        "import torch, os, time",
        "from diffusers import DiffusionPipeline",
        "",
        "print('Downloading Ideogram 4 nf4 model...')",
        "pipe = DiffusionPipeline.from_pretrained(",
        "    'ideogram-ai/ideogram-4-nf4',",
        "    torch_dtype=torch.bfloat16,",
        "    trust_remote_code=True",
        ")",
        "pipe.to('cuda')",
        "print('Ideogram 4 loaded! GPU:', torch.cuda.get_device_name(0))",
        "print('VRAM:', round(torch.cuda.get_device_properties(0).total_mem / 1e9, 1), 'GB')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 4: Generate all 11 ebook covers",
        "OUTPUT = '/content/covers'",
        "os.makedirs(OUTPUT, exist_ok=True)",
        "",
        "covers = [",
        "  # Mycoformed Mars Saga",
        "  ('the-genesis-engine', 'The Genesis Engine',",
        "   'Middle grade science fiction book cover, 1600x2400. Title \"The Genesis Engine\" in large bold futuristic font at the top. Author name \"Daniel Ryan\" in smaller clean font at the bottom. Central illustration: a massive engineered fungal spore pod sitting on the red Martian surface, with a pale blue Earth visible in the orange-tinted Martian sky. The pod has glowing bioluminescent veins. Rocky Martian terrain surrounds it. Art style: clean, bold lines, slightly cartoonish — appealing to middle grade readers (ages 8-12). Colors: reds, oranges, blues, whites. Professional book cover layout with clear title placement. No text errors.'),",
        "  ('the-martian-spore', 'The Martian Spore',",
        "   'Middle grade science fiction book cover, 1600x2400. Title \"The Martian Spore\" in large bold futuristic font at the top. Author name \"Daniel Ryan\" in smaller clean font at the bottom. Central illustration: cracked Martian soil glowing with bright green fungal mycelium spreading across the surface like a network of veins. Small orange warning signs planted in the ground. A white habitat dome sits in the background. Art style: clean, bold lines, slightly cartoonish. Colors: reds, greens, whites, oranges. Professional book cover layout. No text errors.'),",
        "  ('the-crimson-bloom', 'The Crimson Bloom',",
        "   'Middle grade science fiction book cover, 1600x2400. Title \"The Crimson Bloom\" in large bold futuristic font at the top. Author name \"Daniel Ryan\" in smaller clean font at the bottom. Central illustration: view from space showing Mars with a massive crimson-red fungal bloom spreading across the surface in an intricate spiral pattern. A tiny white colony dome sits at the edge of the bloom. Stars in the black space background. Art style: clean, bold lines, slightly cartoonish. Colors: deep reds, blacks, whites, golds. Professional book cover layout. No text errors.'),",
        "  # Sporefall Cycle",
        "  ('sporefall', 'Sporefall',",
        "   'Young adult science fiction horror book cover, 1600x2400. Title \"Sporefall\" in large distressed grunge font at the top. Author name \"Daniel Ryan\" in smaller font at the bottom. Central illustration: a massive terrifying fungal fruiting body emerging from a dark rainforest canopy, releasing thick clouds of yellow-green spores. Tiny human figures with flashlights flee through the undergrowth below. Dark atmospheric lighting. Art style: dramatic, stylized, slightly dark fantasy. Colors: deep greens, blacks, sickly yellows, hints of red. No text errors.'),",
        "  ('mycelial-tide', 'Mycelial Tide',",
        "   'Young adult science fiction horror book cover, 1600x2400. Title \"Mycelial Tide\" in large distressed grunge font at the top. Author name \"Daniel Ryan\" in smaller font at the bottom. Central illustration: a massive wall of white/gray mycelium consuming a modern city street, rising like a tidal wave. Cars and streetlights being overtaken and swallowed. Dramatic low-angle perspective from street level looking up at the approaching wall of fungus. Art style: dramatic, stylized, cinematic. Colors: grays, whites, blacks, touches of red from brake lights. No text errors.'),",
        "  ('mycelial-earth', 'Mycelial Earth',",
        "   'Young adult science fiction horror book cover, 1600x2400. Title \"Mycelial Earth\" in large distressed grunge font at the top. Author name \"Daniel Ryan\" in smaller font at the bottom. Central illustration: planet Earth viewed from space, but the continents are covered in a glowing web of fungal mycelium with bioluminescent nodes. A small spaceship approaches from the foreground. The mycelium pulses with light. Epic scale. Art style: dramatic, stylized, cinematic space art. Colors: blues, greens, blacks, glowing bioluminescent highlights. No text errors.'),",
        "  # My Dog Is Judging Me",
        "  ('the-salami-saboteur', 'The Salami Saboteur',",
        "   'Middle grade mystery humor book cover, 1600x2400. Title \"The Salami Saboteur\" in large playful handwritten-style font at the top. Author name \"Daniel Ryan\" in smaller font at the bottom. Central illustration in hand-drawn doodle/sketch style like Diary of a Wimpy Kid: An orange ginger cat wearing a tiny black domino mask sneaking away with an enormous salami sausage over its shoulder. Behind it, a 9-year-old girl with round glasses and a brown bulldog are looking shocked with exclamation marks above their heads. The bulldog has X-eyes (knocked out). Sketchy pencil-line art with light shading. White background. Fun and kid-friendly. No text errors.'),",
        "  ('the-glass-vaults-gambit', 'The Glass Vaults Gambit',",
        "   'Middle grade mystery humor book cover, 1600x2400. Title \"The Glass Vaults Gambit\" in large playful handwritten-style font at the top. Author name \"Daniel Ryan\" in smaller font at the bottom. Central illustration in hand-drawn doodle/sketch style like Diary of a Wimpy Kid: A nighttime shopping mall interior with a glass skylight showing red laser security beams criss-crossing. An orange ginger cat in a black turtleneck spy outfit crawls through an air duct. A girl with glasses and a bulldog peek from behind a large potted plant. Question marks and exclamation marks floating. Sketchy pencil-line art. White background. No text errors.'),",
        "  # Standalone",
        "  ('station-zero', 'Station Zero',",
        "   'Young adult science fiction book cover, 1600x2400. Title \"Station Zero\" in large bold futuristic font at the top. Author name \"Daniel Ryan\" in smaller clean font at the bottom. Central illustration: a derelict space station floating against a field of stars. One single light still blinks on the station. A small shuttle with its lights on approaches from the foreground. The station has visible damage and missing panels. Cold, vast, lonely feeling. Art style: clean sci-fi, hard edges, realistic proportions. Colors: blacks, blues, whites, orange shuttle lights. No text errors.'),",
        "  ('the-echo-chamber', 'The Echo Chamber',",
        "   'Young adult science fiction thriller book cover, 1600x2400. Title \"The Echo Chamber\" in large bold tech-thriller font with subtle glitch effect at the top. Author name \"Daniel Ryan\" in smaller font at the bottom. Central illustration: a young person's face reflected in a smartphone screen, but their reflection is a slightly uncanny AI avatar with glowing eyes. Digital glitch effects, floating social media notification icons, and streams of data surround the phone. Dark moody lighting. Art style: modern, tech-thriller, slightly cyberpunk. Colors: dark blues, blacks, electric blues, neon accents. No text errors.'),",
        "  ('the-silent-strata', 'The Silent Strata',",
        "   'Young adult science fiction book cover, 1600x2400. Title \"The Silent Strata\" in large bold futuristic font at the top. Author name \"Daniel Ryan\" in smaller clean font at the bottom. Central illustration: a cross-section diagram of the Earth's crust showing geological layers — brown soil on top, then sandstone, then granite, then darker mantle layers going deep. In the deepest darkest layer, an ancient alien geometric structure glows with blue-white light. A tiny drilling machine approaches from above. Art style: clean sci-fi, scientific illustration meets concept art. Colors: browns, grays, blacks, glowing blue-white. No text errors.'),",
        "]",
        "",
        "results = []",
        "for slug, title, prompt in covers:",
        "    print(f'\\nGenerating: {title}...')",
        "    try:",
        "        result = pipe(",
        "            prompt=prompt,",
        "            width=1600,",
        "            height=2400,",
        "            num_inference_steps=30,",
        "            guidance_scale=7.5,",
        "        )",
        "        img = result.images[0]",
        "        path = f'{OUTPUT}/{slug}-ebook-cover.png'",
        "        img.save(path)",
        "        print(f'  ✅ Saved: {path}')",
        "        results.append((title, 'success', path))",
        "    except Exception as e:",
        "        print(f'  ❌ Error: {e}')",
        "        results.append((title, 'error', str(e)))",
        "",
        "print('\\n' + '='*60)",
        "print('GENERATION COMPLETE')",
        "print('='*60)",
        "for title, status, detail in results:",
        "    icon = '✅' if status == 'success' else '❌'",
        "    print(f'{icon} {title}')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 5: Download all covers as ZIP",
        "import shutil",
        "from google.colab import files",
        "",
        "shutil.make_archive('/content/covers_all', 'zip', OUTPUT)",
        "files.download('/content/covers_all.zip')",
        "print('Downloaded: covers_all.zip')",
        "",
        "# Also save individual covers for easy download",
        "print('\\nIndividual cover files:')",
        "for f in sorted(os.listdir(OUTPUT)):",
        "    print(f'  {f}')"
      ]
    },
