# Local 9router / OpenAI-compatible API (default for Hermes)
# AUTONOVEL_API_PROVIDER can be omitted; openai is inferred for localhost.
AUTONOVEL_API_BASE_URL=http://localhost:20128/v1
AUTONOVEL_API_PROVIDER=openai
AUTONOVEL_API_KEY=local

# Writer model (used for drafting and revision)
AUTONOVEL_WRITER_MODEL=openrouter/nex-agi/nex-n2-pro:free

# Judge model (used for evaluation)
AUTONOVEL_JUDGE_MODEL=openrouter/nex-agi/nex-n2-pro:free

# Review model (used in review.py / reader_panel.py)
AUTONOVEL_REVIEW_MODEL=openrouter/nex-agi/nex-n2-pro:free

# Anthropic settings (optional; only needed if AUTONOVEL_API_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
# API_BASE_URL=https://api.anthropic.com

# fal.ai key for image generation (Nano Banana 2)
FAL_KEY=your-fal-api-key-here

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
